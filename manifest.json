{
  "manifest_version": 3,
  "name": "SISREG AIH Client",
  "version": "1.0.0",
  "description": "Browser extension for SISREG AIH data extraction, management, and analysis",
  "permissions": [
    "activeTab",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://sisregiii.saude.gov.br/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SISREG AIH Client",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://sisregiii.saude.gov.br/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": ["sisreg-client.js"],
      "matches": ["https://sisregiii.saude.gov.br/*"]
    }
  ]
}